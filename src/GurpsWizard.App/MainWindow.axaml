<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels"
        xmlns:views="clr-namespace:GurpsWizard.App.Views"
        x:Class="GurpsWizard.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="GURPS Wizard"
        Width="1024" Height="700"
        MinWidth="800" MinHeight="560">

  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
      <views:HomeView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:CharacterListViewModel}">
      <views:CharacterListView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:WizardViewModel}">
      <views:WizardView/>
    </DataTemplate>
  </Window.DataTemplates>

  <ContentControl Content="{Binding CurrentContent}"
                  Margin="20"/>

</Window>
