<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels"
        xmlns:views="clr-namespace:GurpsWizard.App.Views"
        x:Class="GurpsWizard.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="GURPS Wizard"
        Width="1280" Height="850"
        MinWidth="1000" MinHeight="600"
        Background="{DynamicResource ColorBgDeep}">

  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
      <views:HomeView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:CharacterListViewModel}">
      <views:CharacterListView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:WizardViewModel}">
      <views:WizardView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView/>
    </DataTemplate>
  </Window.DataTemplates>

  <Grid ColumnDefinitions="*,Auto,Auto">
    
    <!-- Main Content -->
    <ContentControl Grid.Column="0" Content="{Binding CurrentContent}"/>

    <!-- Vertical Splitter -->
    <GridSplitter Grid.Column="1" Width="1" Background="{DynamicResource ColorBorderRule}" 
                  IsVisible="{Binding PdfViewer.IsOpen}"/>

    <!-- PDF Viewer Styled -->
    <Border Grid.Column="2" Width="550" 
            Background="{DynamicResource ColorBgMain}"
            IsVisible="{Binding PdfViewer.IsOpen}" 
            BorderBrush="{DynamicResource ColorBorderRule}" 
            BorderThickness="1,0,0,0">
      
      <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Header / Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource ColorBgDeep}" Padding="15,12" BorderBrush="{DynamicResource ColorBorderRule}" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding PdfViewer.CurrentTitle}" FontFamily="{StaticResource FontDisplay}" FontSize="12" Foreground="{DynamicResource ColorGoldBright}" TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding PdfViewer.CurrentPageIndex, StringFormat='PÁGINA {0}'}" FontSize="9" LetterSpacing="0.1" Opacity="0.5"/>
            </StackPanel>
            
            <!-- Zoom Controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="0,0,15,0">
              <Button Command="{Binding PdfViewer.ZoomOutCommand}" Classes="StatCardBtn" Content="−"/>
              <TextBlock Text="{Binding PdfViewer.ZoomLevel, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" FontSize="11" Opacity="0.8" Width="45" HorizontalAlignment="Center"/>
              <Button Command="{Binding PdfViewer.ZoomInCommand}" Classes="StatCardBtn" Content="+"/>
            </StackPanel>

            <Button Grid.Column="2" Classes="NavBtnSecondary" Content="✕ FECHAR" Command="{Binding PdfViewer.CloseCommand}" FontSize="10" Padding="8,4"/>
          </Grid>
        </Border>

        <!-- View Area -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#050505">
          <Image Source="{Binding PdfViewer.CurrentPageBitmap}" 
                 Stretch="None" 
                 Margin="10"
                 RenderOptions.BitmapInterpolationMode="HighQuality">
            <Image.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
              </Transitions>
            </Image.Transitions>
          </Image>
        </ScrollViewer>

        <!-- Footer / Navigation -->
        <Border Grid.Row="2" Background="{DynamicResource ColorBgDeep}" Padding="12" BorderBrush="{DynamicResource ColorBorderRule}" BorderThickness="0,1,0,0">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Content="ANTERIOR" Command="{Binding PdfViewer.PrevPageCommand}" Classes="NavBtnSecondary" FontSize="10"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
               <TextBlock Text="PÁGINA" FontSize="9" Opacity="0.5"/>
               <TextBlock Text="{Binding PdfViewer.CurrentPageIndex}" FontWeight="Bold" Foreground="{DynamicResource ColorGoldAccent}"/>
               <TextBlock Text="DE" FontSize="9" Opacity="0.5"/>
               <TextBlock Text="{Binding PdfViewer.TotalPages}" FontWeight="Bold"/>
            </StackPanel>

            <Button Grid.Column="2" Content="PRÓXIMA" Command="{Binding PdfViewer.NextPageCommand}" Classes="NavBtnSecondary" FontSize="10"/>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>

</Window>
