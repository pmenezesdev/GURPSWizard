<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GurpsWizard.App.Views.TraitsView">

  <Grid ColumnDefinitions="*,8,300" RowDefinitions="*,Auto">

    <!-- Coluna esquerda: busca + resultados -->
    <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,Auto,*,Auto">

      <TextBox Grid.Row="0" Text="{Binding SearchQuery}"
               Watermark="Buscar por nome..." Margin="0,0,0,6"/>

      <Grid Grid.Row="1" ColumnDefinitions="*,8,Auto,Auto" Margin="0,0,0,6">
        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"
                  PlaceholderText="Todas as categorias"
                  HorizontalAlignment="Stretch"/>
        <TextBlock Grid.Column="2" Text="Max.:" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7" FontSize="12"/>
        <NumericUpDown Grid.Column="3"
                       Value="{Binding MaxAbsCost}"
                       Minimum="1" Maximum="999"
                       Width="80"
                       ShowButtonSpinner="False"
                       Watermark="pts"
                       ToolTip.Tip="Custo máximo absoluto (pts)"/>
      </Grid>

      <ListBox Grid.Row="2" x:Name="SearchResultsList"
               ItemsSource="{Binding SearchResults}"
               SelectedItem="{Binding SelectedLibraryTrait}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto,Auto" ToolTip.Tip="{Binding Notes}">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Padding="4,2" Margin="4,0"
                      FontSize="10" Foreground="{DynamicResource SystemAccentColor}"
                      Content="{Binding Reference}"
                      Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Abrir PDF na página"/>
              <TextBlock Grid.Column="2" Margin="4,0,0,0"
                         Text="{Binding BasePoints, StringFormat='{}{0} pts'}" VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0" Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding SelectedCanLevel}" VerticalAlignment="Center">
          <TextBlock Text="Nível:" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
          <NumericUpDown Value="{Binding SelectedLevel}"
                         Minimum="1" Maximum="99" Increment="1"
                         Width="70" FormatString="0"
                         ShowButtonSpinner="True"/>
        </StackPanel>
        <TextBlock Text="{Binding PreviewCost, StringFormat='Custo: {0} pts'}"
                   VerticalAlignment="Center" Opacity="0.7" FontSize="12"
                   IsVisible="{Binding SelectedLibraryTrait, Converter={x:Static ObjectConverters.IsNotNull}}"/>
        <Button Content="Adicionar →" Command="{Binding AddCommand}"/>
        <Button Content="+ Personalizado" Command="{Binding ToggleCustomFormCommand}"
                FontSize="11" Padding="8,4"
                ToolTip.Tip="Criar vantagem/desvantagem personalizada"/>
      </StackPanel>
    </Grid>

    <Rectangle Grid.Column="1" Grid.Row="0" Fill="{DynamicResource ColumnDividerColor}"/>

    <!-- Coluna direita: itens adicionados (drop target para drag & drop) -->
    <Grid Grid.Column="2" Grid.Row="0" x:Name="AddedPanel" RowDefinitions="Auto,*,Auto">
      <TextBlock Grid.Row="0" Text="Adicionados" FontWeight="SemiBold" Margin="0,0,0,6"/>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding AddedTraits}"
               SelectedItem="{Binding SelectedAddedTrait}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Margin="4,0,0,0"
                         Text="{Binding Level, StringFormat='Nv.{0}'}"
                         VerticalAlignment="Center" Opacity="0.6" FontSize="11"/>
              <Button Grid.Column="2" Padding="4,2" Margin="4,0"
                      FontSize="10" Foreground="{DynamicResource SystemAccentColor}"
                      Content="{Binding Reference}"
                      Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Abrir PDF na página"/>
              <TextBlock Grid.Column="3" Margin="4,0,0,0"
                         Text="{Binding Cost, StringFormat='{}{0} pts'}"
                         VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Grid.Row="2" Content="Remover selecionado"
              Command="{Binding RemoveSelectedCommand}"
              HorizontalAlignment="Right" Margin="0,6,0,0"/>
    </Grid>

    <!-- Painel de criação personalizada (aparece abaixo) -->
    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Background="{DynamicResource SubtleSurface}" CornerRadius="6"
            Padding="12,10" Margin="0,6,0,0"
            IsVisible="{Binding ShowCustomForm}"
            BorderBrush="{DynamicResource DividerColor}" BorderThickness="1">
      <StackPanel Spacing="8" DataContext="{Binding CustomTraitForm}">
        <TextBlock Text="Criar Personalizado" FontWeight="SemiBold" FontSize="13"/>
        <Grid ColumnDefinitions="*,8,100" RowDefinitions="Auto,8,Auto">
          <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding Name}" Watermark="Nome"/>
          <NumericUpDown Grid.Row="0" Grid.Column="2" Value="{Binding Cost}"
                         Minimum="-999" Maximum="999" Increment="1"
                         FormatString="0" ShowButtonSpinner="True"
                         Watermark="Custo (pts)"/>
          <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding Reference}" Watermark="Referência (opcional)"/>
          <NumericUpDown Grid.Row="2" Grid.Column="2" Value="{Binding Level}"
                         Minimum="1" Maximum="99" Increment="1"
                         FormatString="0" ShowButtonSpinner="True"
                         Watermark="Nível"/>
        </Grid>
        <Button Content="Criar" Command="{Binding CreateCommand}"
                HorizontalAlignment="Right" Padding="12,4"/>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
