<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.TraitsView"
             x:DataType="vm:TraitsViewModel">

  <Grid ColumnDefinitions="*,350" RowDefinitions="*">
    
    <!-- Left: Selection Area -->
    <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,20,0">
      
      <!-- Filters Card -->
      <Border Classes="FeatureCard">
        <StackPanel Spacing="12">
          <TextBox Text="{Binding SearchQuery}" 
                   Watermark="BUSCAR CARACTERÍSTICAS..."
                   Background="Transparent"
                   BorderBrush="{DynamicResource ColorBorderRule}"
                   BorderThickness="0,0,0,1"/>
          
          <Grid ColumnDefinitions="*,150">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      PlaceholderText="TODAS AS CATEGORIAS"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{DynamicResource ColorBorderRule}"/>
            
            <NumericUpDown Grid.Column="1"
                           Value="{Binding MaxAbsCost}"
                           Minimum="1" Maximum="999"
                           Watermark="CUSTO MÁX"
                           Margin="10,0,0,0"
                           Background="Transparent"
                           BorderBrush="{DynamicResource ColorBorderRule}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Selection Grid -->
      <ScrollViewer Height="400">
        <ListBox x:Name="SearchResultsList"
                 Classes="SelectionGrid" 
                 ItemsSource="{Binding SearchResults}"
                 SelectedItem="{Binding SelectedLibraryTrait}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel HorizontalAlignment="Center"/>
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Panel Width="180" Height="45">
                 <!-- Mimic SelBtn state via ListBoxItem selection -->
                 <Border Classes="SelBtn" 
                         Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                   <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Name}" 
                                 TextTrimming="CharacterEllipsis" 
                                 VerticalAlignment="Center" 
                                 HorizontalAlignment="Center"
                                 FontSize="11"
                                 Margin="5,0"/>
                      <Button Grid.Column="1" Classes="RefBtn" Content="{Binding Reference}"
                              Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                              CommandParameter="{Binding}"
                              IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                              Margin="0,0,5,0"/>
                   </Grid>
                 </Border>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>

      <!-- Action Area -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
         <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding SelectedCanLevel}" VerticalAlignment="Center">
            <TextBlock Text="NÍVEL:" VerticalAlignment="Center" FontSize="10" Opacity="0.6"/>
            <NumericUpDown Value="{Binding SelectedLevel}" Minimum="1" Width="80"/>
         </StackPanel>
         <Button Classes="NavBtnPrimary" Content="ADICIONAR" Command="{Binding AddCommand}"/>
         <Button Classes="NavBtnSecondary" Content="+ PERSONALIZAR" Command="{Binding ToggleCustomFormCommand}"/>
      </StackPanel>
    </StackPanel>

    <!-- Right: Added List -->
    <Border x:Name="AddedPanel" Grid.Column="1" Classes="FeatureCard">
      <Grid RowDefinitions="Auto,1,*,Auto">
        <TextBlock Grid.Row="0" Text="SELECIONADOS" 
                   HorizontalAlignment="Center" FontSize="12" LetterSpacing="0.1" Margin="0,0,0,10"/>
        <Rectangle Grid.Row="1" Fill="{DynamicResource ColorBorderRule}" Margin="0,0,0,10"/>
        
        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding AddedTraits}" 
                 SelectedItem="{Binding SelectedAddedTrait}"
                 Background="Transparent" BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
               <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                 <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" TextWrapping="Wrap"/>
                 <Button Grid.Column="1" Classes="RefBtn" Content="{Binding Reference}"
                         Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                         CommandParameter="{Binding}"
                         IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Margin="5,0"/>
                 <TextBlock Grid.Column="2" Text="{Binding Level, StringFormat='v{0}'}" 
                            FontSize="9" Opacity="0.5" Margin="5,0" VerticalAlignment="Center"/>
                 <TextBlock Grid.Column="3" Text="{Binding Cost, StringFormat='{}{0} pts'}" 
                            FontSize="11" Opacity="0.8" VerticalAlignment="Center"/>
               </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="3" 
                Classes="NavBtnSecondary" 
                Content="REMOVER SELECIONADO" 
                Command="{Binding RemoveSelectedCommand}"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                FontSize="10"/>
      </Grid>
    </Border>

    <!-- Custom Form Overlay -->
    <Border Grid.ColumnSpan="2" 
            Classes="FeatureCard" 
            VerticalAlignment="Bottom" 
            IsVisible="{Binding ShowCustomForm}"
            BoxShadow="0 0 20 5 #80000000">
       <StackPanel Spacing="10" DataContext="{Binding CustomTraitForm}">
          <TextBlock Text="CRIAR CARACTERÍSTICA PERSONALIZADA" FontSize="12" HorizontalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" Spacing="10">
             <TextBox Text="{Binding Name}" Watermark="NOME" Width="250"/>
             <NumericUpDown Value="{Binding Cost}" Watermark="PTS" Width="100"/>
             <NumericUpDown Value="{Binding Level}" Watermark="NÍVEL" Width="100"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
             <Button Classes="NavBtnSecondary" Content="CANCELAR" Command="{Binding $parent[UserControl].DataContext.ToggleCustomFormCommand}"/>
             <Button Classes="NavBtnPrimary" Content="CRIAR" Command="{Binding CreateCommand}"/>
          </StackPanel>
       </StackPanel>
    </Border>

  </Grid>
</UserControl>
