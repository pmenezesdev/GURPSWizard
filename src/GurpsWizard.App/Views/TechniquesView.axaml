<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GurpsWizard.App.Views.TechniquesView">

  <Grid ColumnDefinitions="*,8,300" RowDefinitions="*">

    <!-- Coluna esquerda: busca + filtros + resultados -->
    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

      <TextBox Grid.Row="0" Text="{Binding SearchQuery}"
               Watermark="Buscar técnica ou perícia pai..." Margin="0,0,0,6"/>

      <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,0,0,6">
        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding Difficulties}"
                  SelectedItem="{Binding SelectedDifficulty}"
                  PlaceholderText="Dificuldade"
                  HorizontalAlignment="Stretch"
                  ToolTip.Tip="A = Média · H = Difícil"/>
        <ComboBox Grid.Column="2"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"
                  PlaceholderText="Categoria"
                  HorizontalAlignment="Stretch"/>
      </Grid>

      <TextBlock Grid.Row="2"
                 Text="Técnicas são ações específicas dentro de uma perícia. O custo é relativo ao valor predefinido da técnica (não ao atributo)."
                 Opacity="0.6" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,6"/>

      <ListBox Grid.Row="3" x:Name="SearchResultsList"
               ItemsSource="{Binding SearchResults}"
               SelectedItem="{Binding SelectedLibraryTechnique}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto,Auto,50" ToolTip.Tip="{Binding Notes}">
              <TextBlock Grid.Column="0" Text="{Binding DisplayName}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <Border Grid.Column="1" Background="{DynamicResource SubtleSurface}" CornerRadius="3"
                      Padding="4,1" Margin="4,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Difficulty}" FontSize="10" Opacity="0.7"/>
              </Border>
              <Button Grid.Column="2" Padding="4,2" Margin="4,0"
                      FontSize="10" Foreground="{DynamicResource SystemAccentColor}"
                      Content="{Binding Reference}"
                      Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Abrir PDF na página"/>
              <!-- MaxAboveDefault: mostra limite máximo quando definido -->
              <TextBlock Grid.Column="3"
                         Text="{Binding MaxAboveDefault, StringFormat='máx +{0}'}"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         FontSize="10" Opacity="0.5"
                         IsVisible="{Binding MaxAboveDefault, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Seleção de níveis acima do predefinido -->
      <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,8,0,4">
        <TextBlock Grid.Column="0" Text="Níveis acima do predefinido:" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <NumericUpDown Grid.Column="1" Value="{Binding LevelsAboveDefault}"
                       Minimum="0" Maximum="10"/>
        <TextBlock Grid.Column="2" Text="Custo:" VerticalAlignment="Center" Margin="12,0,8,0"/>
        <TextBlock Grid.Column="3" Text="{Binding PreviewCost, StringFormat='{}{0} pts'}"
                   VerticalAlignment="Center" FontWeight="SemiBold"/>
      </Grid>

      <Button Grid.Row="5" Content="Adicionar" Command="{Binding AddCommand}"
              HorizontalAlignment="Right"/>
    </Grid>

    <Rectangle Grid.Column="1" Fill="{DynamicResource ColumnDividerColor}"/>

    <!-- Coluna direita: técnicas adicionadas -->
    <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
      <TextBlock Grid.Row="0" Text="Técnicas selecionadas" FontWeight="SemiBold" Margin="0,0,0,6"/>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding AddedTechniques}"
               SelectedItem="{Binding SelectedAddedTechnique}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto,40,50">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Padding="4,2" Margin="4,0"
                      FontSize="10" Foreground="{DynamicResource SystemAccentColor}"
                      Content="{Binding Reference}"
                      Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Abrir PDF na página"/>
              <TextBlock Grid.Column="2" Text="{Binding LevelsAboveDefault, StringFormat='{}{0:+#;-#;0}'}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
              <TextBlock Grid.Column="3" Text="{Binding Cost, StringFormat='{}{0} pts'}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Grid.Row="2" Content="Remover selecionado"
              Command="{Binding RemoveSelectedCommand}"
              HorizontalAlignment="Right" Margin="0,6,0,0"/>
    </Grid>

  </Grid>
</UserControl>
