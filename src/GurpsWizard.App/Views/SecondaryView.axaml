<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.SecondaryView"
             x:DataType="vm:SecondaryViewModel">

  <StackPanel HorizontalAlignment="Center">
    <UniformGrid Columns="3" MaxWidth="800" HorizontalAlignment="Center">
      
      <!-- HP -->
      <Border Classes="StatCard" Margin="6">
        <StackPanel Spacing="8">
          <TextBlock Classes="StatCardName" Text="PONTOS DE VIDA (PV)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementHP}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding HP}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementHP}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostHP, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="10"/>
        </StackPanel>
      </Border>

      <!-- FP -->
      <Border Classes="StatCard" Margin="6">
        <StackPanel Spacing="8">
          <TextBlock Classes="StatCardName" Text="PONTOS DE FADIGA (PF)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementFP}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding FP}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementFP}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostFP, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="10"/>
        </StackPanel>
      </Border>

      <!-- WILL -->
      <Border Classes="StatCard" Margin="6">
        <StackPanel Spacing="8">
          <TextBlock Classes="StatCardName" Text="VONTADE"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementWill}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding Will}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementWill}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostWill, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="10"/>
        </StackPanel>
      </Border>

      <!-- PER -->
      <Border Classes="StatCard" Margin="6">
        <StackPanel Spacing="8">
          <TextBlock Classes="StatCardName" Text="PERCEPÇÃO (PER)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementPer}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding Per}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementPer}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostPer, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="10"/>
        </StackPanel>
      </Border>

      <!-- SPEED -->
      <Border Classes="StatCard" Margin="6">
        <StackPanel Spacing="8">
          <TextBlock Classes="StatCardName" Text="VELOCIDADE BÁSICA"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementSpeed}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding BasicSpeed}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementSpeed}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostBasicSpeed, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="10"/>
        </StackPanel>
      </Border>

      <!-- MOVE -->
      <Border Classes="StatCard" Margin="6">
        <StackPanel Spacing="8">
          <TextBlock Classes="StatCardName" Text="DESLOCAMENTO BÁSICO"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementMove}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding BasicMove}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementMove}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostBasicMove, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="10"/>
        </StackPanel>
      </Border>

    </UniformGrid>

    <TextBlock Margin="0,20,0,0" Opacity="0.5" FontSize="10" HorizontalAlignment="Center"
               Text="PV/PF/Vontade/Per = 2 pts/nível · Velocidade(+0.25) = 5 pts · Deslocamento = 5 pts/nível"/>
  </StackPanel>
</UserControl>
