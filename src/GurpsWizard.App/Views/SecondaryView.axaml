<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.SecondaryView"
             x:DataType="vm:SecondaryViewModel">

  <StackPanel Spacing="6" MaxWidth="520" HorizontalAlignment="Left">

    <TextBlock Text="Atributos Secundários" Classes="SectionTitle" Margin="0,0,0,8"/>

    <!-- PV -->
    <Grid ColumnDefinitions="140,80,120,80,*">
      <TextBlock Grid.Column="0" Text="PV (Pontos de Vida)" VerticalAlignment="Center" Classes="FieldLabel"/>
      <TextBlock Grid.Column="1" Text="{Binding HP}" VerticalAlignment="Center" Classes="ValueLabel"/>
      <TextBlock Grid.Column="2" Text="Bônus:" VerticalAlignment="Center" Opacity="0.7"/>
      <NumericUpDown Grid.Column="3" Value="{Binding HPBonus}" Minimum="-5" Maximum="30" Classes="Field"/>
      <TextBlock Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                 Text="{Binding CostHP, StringFormat='{}{0:+#;-#;0} pts'}" Classes="CostLabel"/>
    </Grid>

    <!-- PM -->
    <Grid ColumnDefinitions="140,80,120,80,*">
      <TextBlock Grid.Column="0" Text="PM (Pontos de Fadiga)" VerticalAlignment="Center" Classes="FieldLabel"/>
      <TextBlock Grid.Column="1" Text="{Binding FP}" VerticalAlignment="Center" Classes="ValueLabel"/>
      <TextBlock Grid.Column="2" Text="Bônus:" VerticalAlignment="Center" Opacity="0.7"/>
      <NumericUpDown Grid.Column="3" Value="{Binding FPBonus}" Minimum="-5" Maximum="30" Classes="Field"/>
      <TextBlock Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                 Text="{Binding CostFP, StringFormat='{}{0:+#;-#;0} pts'}" Classes="CostLabel"/>
    </Grid>

    <!-- Vontade -->
    <Grid ColumnDefinitions="140,80,120,80,*">
      <TextBlock Grid.Column="0" Text="Vontade" VerticalAlignment="Center" Classes="FieldLabel"/>
      <TextBlock Grid.Column="1" Text="{Binding Will}" VerticalAlignment="Center" Classes="ValueLabel"/>
      <TextBlock Grid.Column="2" Text="Bônus:" VerticalAlignment="Center" Opacity="0.7"/>
      <NumericUpDown Grid.Column="3" Value="{Binding WillBonus}" Minimum="-5" Maximum="20" Classes="Field"/>
      <TextBlock Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                 Text="{Binding CostWill, StringFormat='{}{0:+#;-#;0} pts'}" Classes="CostLabel"/>
    </Grid>

    <!-- Per -->
    <Grid ColumnDefinitions="140,80,120,80,*">
      <TextBlock Grid.Column="0" Text="Percepção" VerticalAlignment="Center" Classes="FieldLabel"/>
      <TextBlock Grid.Column="1" Text="{Binding Per}" VerticalAlignment="Center" Classes="ValueLabel"/>
      <TextBlock Grid.Column="2" Text="Bônus:" VerticalAlignment="Center" Opacity="0.7"/>
      <NumericUpDown Grid.Column="3" Value="{Binding PerBonus}" Minimum="-5" Maximum="20" Classes="Field"/>
      <TextBlock Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                 Text="{Binding CostPer, StringFormat='{}{0:+#;-#;0} pts'}" Classes="CostLabel"/>
    </Grid>

    <!-- Vel. Básica -->
    <Grid ColumnDefinitions="140,80,120,80,*">
      <TextBlock Grid.Column="0" Text="Vel. Básica" VerticalAlignment="Center" Classes="FieldLabel"/>
      <TextBlock Grid.Column="1" Text="{Binding BasicSpeed}" VerticalAlignment="Center" Classes="ValueLabel"/>
      <TextBlock Grid.Column="2" Text="Bônus (+0.25):" VerticalAlignment="Center" Opacity="0.7"/>
      <NumericUpDown Grid.Column="3" Value="{Binding BasicSpeedBonus}" Minimum="0" Maximum="20" Classes="Field"/>
      <TextBlock Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                 Text="{Binding CostBasicSpeed, StringFormat='{}{0:+#;-#;0} pts'}" Classes="CostLabel"/>
    </Grid>

    <!-- Deslocamento -->
    <Grid ColumnDefinitions="140,80,120,80,*">
      <TextBlock Grid.Column="0" Text="Deslocamento" VerticalAlignment="Center" Classes="FieldLabel"/>
      <TextBlock Grid.Column="1" Text="{Binding BasicMove}" VerticalAlignment="Center" Classes="ValueLabel"/>
      <TextBlock Grid.Column="2" Text="Bônus:" VerticalAlignment="Center" Opacity="0.7"/>
      <NumericUpDown Grid.Column="3" Value="{Binding BasicMoveBonus}" Minimum="0" Maximum="20" Classes="Field"/>
      <TextBlock Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                 Text="{Binding CostBasicMove, StringFormat='{}{0:+#;-#;0} pts'}" Classes="CostLabel"/>
    </Grid>

    <TextBlock Margin="0,8,0,0" Opacity="0.6" FontSize="12"
               Text="PV/PM/Vontade/Per = 2 pts/nível · Vel.(+0.25) = 5 pts · Desl. = 5 pts/nível"/>

  </StackPanel>
</UserControl>
