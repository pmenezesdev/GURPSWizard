<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.ReviewView"
             x:DataType="vm:ReviewViewModel">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Classes="FinalScreenContent" Margin="0,0,0,40">
      
      <TextBlock Classes="FinalScreenTitle" 
                 Text="Pronto para embarcar em sua jornada, aventureiro?"/>

      <StackPanel Classes="StartBtnWrapper">
        <TextBlock Classes="StartBtnOrnament" Text="❖"/>
        <Button Classes="StartBtn" 
                Content="INICIAR AVENTURA" 
                Command="{Binding SaveCommand}"/>
        <TextBlock Classes="StartBtnOrnament" Text="❖"/>
      </StackPanel>

      <TextBlock Text="{Binding SaveStatus}" 
                 HorizontalAlignment="Center" 
                 FontSize="11" 
                 Foreground="{DynamicResource ColorGoldMid}"
                 IsVisible="{Binding SaveStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <!-- Comprehensive Sheet Grid -->
      <Grid ColumnDefinitions="*,*" Width="1000" Margin="0,20,0,0">
        
        <!-- Left Column -->
        <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,10,0">
          
          <!-- Character Basics -->
          <Border Classes="FeatureCard">
            <StackPanel Spacing="8">
               <TextBlock Text="PERSONAGEM" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
               <TextBlock Text="{Binding Draft.Name}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ColorGoldAccent}"/>
               <Rectangle Height="1" Fill="{DynamicResource ColorBorderRule}" Margin="0,5"/>
               <TextBlock Text="{Binding Draft.Description}" FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- Attributes Grid -->
          <Border Classes="FeatureCard">
            <StackPanel Spacing="12">
               <TextBlock Text="ATRIBUTOS" FontSize="9" Opacity="0.5" LetterSpacing="0.1" HorizontalAlignment="Center"/>
               <UniformGrid Columns="4">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ST" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.Attributes.ST}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="DX" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.Attributes.DX}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="IQ" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.Attributes.IQ}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="HT" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.Attributes.HT}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
               </UniformGrid>
               
               <Rectangle Height="1" Fill="{DynamicResource ColorBorderRule}" Opacity="0.3"/>
               
               <UniformGrid Columns="3">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="PV" FontSize="9" Opacity="0.5" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.SecondaryAttributes.HPBonus, StringFormat='{}{0:+#;-#;10}'}" FontSize="14" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="VONT" FontSize="9" Opacity="0.5" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.SecondaryAttributes.WillBonus, StringFormat='{}{0:+#;-#;10}'}" FontSize="14" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="PER" FontSize="9" Opacity="0.5" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Draft.SecondaryAttributes.PerBonus, StringFormat='{}{0:+#;-#;10}'}" FontSize="14" HorizontalAlignment="Center"/>
                  </StackPanel>
               </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Traits List -->
          <Border Classes="FeatureCard">
             <StackPanel Spacing="10">
                <TextBlock Text="VANTAGENS &amp; DESVANTAGENS" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
                <ItemsControl ItemsSource="{Binding Draft.Advantages}">
                   <ItemsControl.ItemTemplate>
                      <DataTemplate>
                         <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Cost, StringFormat='{}{0} pts'}" FontSize="11" Opacity="0.6" Margin="10,0,0,0"/>
                         </Grid>
                      </DataTemplate>
                   </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Rectangle Height="1" Fill="{DynamicResource ColorBorderRule}" Opacity="0.3"/>
                <ItemsControl ItemsSource="{Binding Draft.Disadvantages}">
                   <ItemsControl.ItemTemplate>
                      <DataTemplate>
                         <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Cost, StringFormat='{}{0} pts'}" FontSize="11" Opacity="0.6" Margin="10,0,0,0"/>
                         </Grid>
                      </DataTemplate>
                   </ItemsControl.ItemTemplate>
                </ItemsControl>
             </StackPanel>
          </Border>

        </StackPanel>

        <!-- Right Column -->
        <StackPanel Grid.Column="1" Spacing="15" Margin="10,0,0,0">
          
          <!-- Points Breakdown -->
          <Border Classes="FeatureCard">
            <StackPanel Spacing="8">
               <TextBlock Text="DIVISÃO DE PONTOS" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
               <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Atributos" FontSize="11" Opacity="0.7"/>
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SpentAttributes}" FontSize="11"/>
                  
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Secundários" FontSize="11" Opacity="0.7"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SpentSecondary}" FontSize="11"/>
                  
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Vantagens" FontSize="11" Opacity="0.7"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Points.SpentAdvantages}" FontSize="11"/>
                  
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Desvantagens" FontSize="11" Opacity="0.7"/>
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Points.SpentDisadvantages}" FontSize="11"/>
                  
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Perícias" FontSize="11" Opacity="0.7"/>
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SpentSkills}" FontSize="11"/>
               </Grid>
               <Rectangle Height="1" Fill="{DynamicResource ColorBorderRule}" Margin="0,5"/>
               <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="TOTAL GASTO" FontWeight="Bold"/>
                  <TextBlock Grid.Column="1" Text="{Binding Points.Spent, StringFormat='{}{0} / {1}'}" FontWeight="Bold" Foreground="{DynamicResource ColorGoldAccent}"/>
               </Grid>
            </StackPanel>
          </Border>

          <!-- Skills List -->
          <Border Classes="FeatureCard">
             <StackPanel Spacing="10">
                <TextBlock Text="PERÍCIAS" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
                <ItemsControl ItemsSource="{Binding Draft.Skills}">
                   <ItemsControl.ItemTemplate>
                      <DataTemplate>
                         <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Level, StringFormat='({0})'}" FontSize="11" Opacity="0.5" Margin="10,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Cost, StringFormat='{}{0} pts'}" FontSize="11" Opacity="0.6"/>
                         </Grid>
                      </DataTemplate>
                   </ItemsControl.ItemTemplate>
                </ItemsControl>
             </StackPanel>
          </Border>

          <!-- Techniques List -->
          <Border Classes="FeatureCard"
                  IsVisible="{Binding Draft.Techniques.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
             <StackPanel Spacing="10">
                <TextBlock Text="TÉCNICAS" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
                <ItemsControl ItemsSource="{Binding Draft.Techniques}">
                   <ItemsControl.ItemTemplate>
                      <DataTemplate>
                         <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding LevelsAboveDefault, StringFormat='(+{0})'}" FontSize="11" Opacity="0.5" Margin="10,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Cost, StringFormat='{}{0} pts'}" FontSize="11" Opacity="0.6"/>
                         </Grid>
                      </DataTemplate>
                   </ItemsControl.ItemTemplate>
                </ItemsControl>
             </StackPanel>
          </Border>

          <!-- Spells List -->
          <Border Classes="FeatureCard"
                  IsVisible="{Binding Draft.Spells.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
             <StackPanel Spacing="10">
                <TextBlock Text="MÁGICAS" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
                <ItemsControl ItemsSource="{Binding Draft.Spells}">
                   <ItemsControl.ItemTemplate>
                      <DataTemplate>
                         <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding College}" FontSize="9" Opacity="0.5" Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Level, StringFormat='({0})'}" FontSize="11" Opacity="0.5" Margin="8,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding Cost, StringFormat='{}{0} pts'}" FontSize="11" Opacity="0.6"/>
                         </Grid>
                      </DataTemplate>
                   </ItemsControl.ItemTemplate>
                </ItemsControl>
             </StackPanel>
          </Border>

          <!-- Equipment List -->
          <Border Classes="FeatureCard">
             <StackPanel Spacing="10">
                <TextBlock Text="INVENTÁRIO" FontSize="9" Opacity="0.5" LetterSpacing="0.1"/>
                <ItemsControl ItemsSource="{Binding Draft.Equipment}">
                   <ItemsControl.ItemTemplate>
                      <DataTemplate>
                         <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0}x'}" FontSize="10" Opacity="0.5" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat='${0:N0}'}" FontSize="11" Opacity="0.6"/>
                         </Grid>
                      </DataTemplate>
                   </ItemsControl.ItemTemplate>
                </ItemsControl>
             </StackPanel>
          </Border>

          <!-- Final Actions -->
          <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,10">
             <Button Classes="NavBtnSecondary" Content="EXPORTAR JSON" Command="{Binding ExportCommand}" FontSize="10"/>
             <Button Classes="NavBtnSecondary" Content="EXPORTAR GCS" Command="{Binding ExportGcsCommand}" FontSize="10"/>
          </StackPanel>

        </StackPanel>

      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
