<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.EquipmentView"
             x:DataType="vm:EquipmentViewModel">

  <Grid ColumnDefinitions="*,380" RowDefinitions="*">
    
    <!-- Left: Selection Area -->
    <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,20,0">
      
      <!-- Filters Card -->
      <Border Classes="FeatureCard">
        <StackPanel Spacing="12">
          <TextBox Text="{Binding SearchQuery}" 
                   Watermark="BUSCAR EQUIPAMENTOS..."
                   Background="Transparent"
                   BorderBrush="{DynamicResource ColorBorderRule}"
                   BorderThickness="0,0,0,1"/>
          
          <ComboBox ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory}"
                    PlaceholderText="TODAS AS CATEGORIAS"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    BorderBrush="{DynamicResource ColorBorderRule}"/>
        </StackPanel>
      </Border>

      <!-- Selection Grid -->
      <ScrollViewer Height="400">
        <ListBox x:Name="SearchResultsList"
                 Classes="SelectionGrid" 
                 ItemsSource="{Binding SearchResults}"
                 SelectedItem="{Binding SelectedLibraryEquipment}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel HorizontalAlignment="Center"/>
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Panel Width="220" Height="60">
                 <Border Classes="SelBtn" 
                         Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                   <Grid RowDefinitions="*,Auto">
                      <Grid ColumnDefinitions="*,Auto">
                         <TextBlock Text="{Binding Name}" 
                                    TextTrimming="CharacterEllipsis" 
                                    VerticalAlignment="Center" 
                                    FontSize="11"
                                    Margin="5,0"/>
                         <Button Grid.Column="1" Classes="RefBtn" Content="{Binding Reference}"
                                 Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                                 CommandParameter="{Binding}"
                                 IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                 Margin="0,0,5,0"/>
                      </Grid>
                      <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,0,5,2" Opacity="0.6">
                         <TextBlock Text="{Binding TechLevel, StringFormat='NT{0}'}" FontSize="8" Margin="0,0,10,0" IsVisible="{Binding TechLevel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                         <TextBlock Text="{Binding Value, StringFormat='${0:N0}'}" FontSize="9" Margin="5,0"/>
                         <TextBlock Text="{Binding Weight}" FontSize="9"/>
                      </StackPanel>
                   </Grid>
                 </Border>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>

      <!-- Action Area -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
         <Button Classes="NavBtnPrimary" Content="ADICIONAR AO INVENTÁRIO" Command="{Binding AddCommand}"/>
         <Button Classes="NavBtnSecondary" Content="+ PERSONALIZAR" Command="{Binding ToggleCustomFormCommand}"/>
      </StackPanel>
    </StackPanel>

    <!-- Right: Inventory List -->
    <Border x:Name="AddedPanel" Grid.Column="1" Classes="FeatureCard">
      <Grid RowDefinitions="Auto,1,*,Auto,Auto">
        <TextBlock Grid.Row="0" Text="INVENTÁRIO" 
                   HorizontalAlignment="Center" FontSize="12" LetterSpacing="0.1" Margin="0,0,0,10"/>
        <Rectangle Grid.Row="1" Fill="{DynamicResource ColorBorderRule}" Margin="0,0,0,10"/>
        
        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding AddedEquipment}" 
                 SelectedItem="{Binding SelectedAddedEquipment}"
                 Background="Transparent" BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
               <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                 <TextBlock Grid.Column="0" Text="{Binding Quantity, StringFormat='{}{0}x'}" 
                            FontSize="10" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                 <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11" TextWrapping="Wrap"/>
                 <TextBlock Grid.Column="2" Text="{Binding TechLevel, StringFormat='NT{0}'}" FontSize="8" Opacity="0.5" VerticalAlignment="Center" Margin="5,0" IsVisible="{Binding TechLevel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                 <Button Grid.Column="3" Classes="RefBtn" Content="{Binding Reference}"
                         Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                         CommandParameter="{Binding}"
                         IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Margin="5,0"/>
                 <TextBlock Grid.Column="4" Text="{Binding Value, StringFormat='${0:N2}'}" 
                            FontSize="10" Opacity="0.6" Margin="8,0" VerticalAlignment="Center"/>
               </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Totals -->
        <Border Grid.Row="3" Background="#20000000" CornerRadius="4" Padding="10" Margin="0,10,0,0">
           <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
              <StackPanel>
                 <TextBlock Text="VALOR TOTAL" FontSize="8" Opacity="0.5" HorizontalAlignment="Center"/>
                 <TextBlock Text="{Binding TotalValue, StringFormat='${0:N2}'}" FontSize="12" FontWeight="SemiBold"/>
              </StackPanel>
              <StackPanel>
                 <TextBlock Text="PESO TOTAL" FontSize="8" Opacity="0.5" HorizontalAlignment="Center"/>
                 <TextBlock Text="{Binding TotalWeight}" FontSize="12" FontWeight="SemiBold"/>
              </StackPanel>
           </StackPanel>
        </Border>

        <Button Grid.Row="4" 
                Classes="NavBtnSecondary" 
                Content="REMOVER SELECIONADO" 
                Command="{Binding RemoveSelectedCommand}"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                FontSize="10"/>
      </Grid>
    </Border>

    <!-- Custom Form Overlay -->
    <Border Grid.ColumnSpan="2" 
            Classes="FeatureCard" 
            VerticalAlignment="Bottom" 
            IsVisible="{Binding ShowCustomForm}"
            BoxShadow="0 0 20 5 #80000000">
       <StackPanel Spacing="10" DataContext="{Binding CustomEquipmentForm}">
          <TextBlock Text="CRIAR EQUIPAMENTO PERSONALIZADO" FontSize="12" HorizontalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" Spacing="10">
             <TextBox Text="{Binding Name}" Watermark="NOME DO ITEM" Width="200"/>
             <NumericUpDown Value="{Binding Value}" Watermark="VALOR ($)" Width="100"/>
             <TextBox Text="{Binding Weight}" Watermark="PESO" Width="100"/>
             <NumericUpDown Value="{Binding Quantity}" Minimum="1" Watermark="QTD" Width="100"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
             <Button Classes="NavBtnSecondary" Content="CANCELAR" Command="{Binding $parent[UserControl].DataContext.ToggleCustomFormCommand}"/>
             <Button Classes="NavBtnPrimary" Content="CRIAR" Command="{Binding CreateCommand}"/>
          </StackPanel>
       </StackPanel>
    </Border>

  </Grid>
</UserControl>
