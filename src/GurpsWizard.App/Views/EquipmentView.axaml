<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GurpsWizard.App.Views.EquipmentView">

  <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,8,300">

    <!-- Coluna esquerda: busca + resultados -->
    <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*,Auto">

      <TextBox Grid.Row="0" Text="{Binding SearchQuery}"
               Watermark="Buscar equipamento..." Margin="0,0,0,6"/>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding SearchResults}"
               SelectedItem="{Binding SelectedLibraryEquipment}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,70,70">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat='$ {0:N2}'}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
              <TextBlock Grid.Column="2" Text="{Binding Weight}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Grid.Row="2" Content="Adicionar →"
              Command="{Binding AddCommand}"
              HorizontalAlignment="Right" Margin="0,6,0,0"/>
    </Grid>

    <Rectangle Grid.Column="1" Grid.Row="0" Fill="#44FFFFFF"/>

    <!-- Coluna direita: equipamentos selecionados -->
    <Grid Grid.Column="2" Grid.Row="0" RowDefinitions="Auto,*,Auto">
      <TextBlock Grid.Row="0" Text="Equipamento selecionado" FontWeight="SemiBold" Margin="0,0,0,6"/>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding AddedEquipment}"
               SelectedItem="{Binding SelectedAddedEquipment}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,70">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat='$ {0:N2}'}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Grid.Row="2" Content="Remover selecionado"
              Command="{Binding RemoveSelectedCommand}"
              HorizontalAlignment="Right" Margin="0,6,0,0"/>
    </Grid>

    <!-- Rodapé de totais -->
    <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
            Background="#22FFFFFF" CornerRadius="4" Margin="0,8,0,0" Padding="12,6">
      <StackPanel Orientation="Horizontal" Spacing="24">
        <TextBlock>
          <Run Text="Custo total: "/>
          <Run Text="{Binding TotalValue, StringFormat='$ {0:N2}'}"/>
        </TextBlock>
        <TextBlock>
          <Run Text="Peso total: "/>
          <Run Text="{Binding TotalWeight}"/>
        </TextBlock>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
