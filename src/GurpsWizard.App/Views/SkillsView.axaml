<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GurpsWizard.App.Views.SkillsView">

  <Grid ColumnDefinitions="*,8,300" RowDefinitions="*">

    <!-- Coluna esquerda: busca + resultados -->
    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

      <TextBox Grid.Row="0" Text="{Binding SearchQuery}"
               Watermark="Buscar perícia..." Margin="0,0,0,6"/>

      <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,0,0,6">
        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding Attributes}"
                  SelectedItem="{Binding SelectedAttribute}"
                  PlaceholderText="Atributo"
                  HorizontalAlignment="Stretch"
                  ToolTip.Tip="ST = Força · DX = Destreza · IQ = Inteligência · HT = Vitalidade"/>
        <ComboBox Grid.Column="2"
                  ItemsSource="{Binding Difficulties}"
                  SelectedItem="{Binding SelectedDifficulty}"
                  PlaceholderText="Dificuldade"
                  HorizontalAlignment="Stretch"
                  ToolTip.Tip="E = Fácil · A = Médio · H = Difícil · VH = Muito Difícil"/>
      </Grid>

      <ComboBox Grid.Row="2"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                PlaceholderText="Categoria"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,6"/>

      <ListBox Grid.Row="3" x:Name="SearchResultsList"
               ItemsSource="{Binding SearchResults}"
               SelectedItem="{Binding SelectedLibrarySkill}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto,50,50" ToolTip.Tip="{Binding Notes}">
              <TextBlock Grid.Column="0" Text="{Binding DisplayName}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Padding="4,2" Margin="4,0"
                      FontSize="10" Foreground="{DynamicResource SystemAccentColor}"
                      Content="{Binding Reference}"
                      Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Abrir PDF na página"/>
              <TextBlock Grid.Column="2" Text="{Binding BaseAttribute}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
              <TextBlock Grid.Column="3" Text="{Binding Difficulty}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Seleção de nível relativo -->
      <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,8,0,4">
        <TextBlock Grid.Column="0" Text="Nível relativo:" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <NumericUpDown Grid.Column="1" Value="{Binding RelativeLevel}"
                       Minimum="-3" Maximum="10"/>
        <TextBlock Grid.Column="2" Text="Custo:" VerticalAlignment="Center" Margin="12,0,8,0"/>
        <TextBlock Grid.Column="3" Text="{Binding PreviewCost, StringFormat='{}{0} pts'}"
                   VerticalAlignment="Center" FontWeight="SemiBold"/>
      </Grid>

      <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Adicionar" Command="{Binding AddCommand}"/>
        <Button Content="+ Personalizado" Command="{Binding ToggleCustomFormCommand}"
                FontSize="11" Padding="8,4"
                ToolTip.Tip="Criar perícia personalizada"/>
      </StackPanel>
    </Grid>

    <!-- Painel de criação personalizada -->
    <Border Grid.Column="0" Grid.ColumnSpan="3"
            Background="{DynamicResource SubtleSurface}" CornerRadius="6"
            Padding="12,10" Margin="0,6,0,0"
            IsVisible="{Binding ShowCustomForm}"
            BorderBrush="{DynamicResource DividerColor}" BorderThickness="1"
            VerticalAlignment="Bottom">
      <StackPanel Spacing="8" DataContext="{Binding CustomSkillForm}">
        <TextBlock Text="Criar Perícia Personalizada" FontWeight="SemiBold" FontSize="13"/>
        <Grid ColumnDefinitions="*,8,100,8,100" RowDefinitions="Auto,8,Auto">
          <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding Name}" Watermark="Nome"/>
          <ComboBox Grid.Row="0" Grid.Column="2"
                    ItemsSource="{Binding BaseAttributes}"
                    SelectedItem="{Binding BaseAttribute}"
                    HorizontalAlignment="Stretch"/>
          <ComboBox Grid.Row="0" Grid.Column="4"
                    ItemsSource="{Binding Difficulties}"
                    SelectedItem="{Binding Difficulty}"
                    HorizontalAlignment="Stretch"/>
          <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="Nível relativo:" VerticalAlignment="Center" Opacity="0.7"/>
            <NumericUpDown Value="{Binding RelativeLevel}"
                           Minimum="-3" Maximum="10" Increment="1"
                           Width="80" FormatString="0"/>
            <TextBlock Text="{Binding PreviewCost, StringFormat='Custo: {0} pts'}"
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
          </StackPanel>
        </Grid>
        <Button Content="Criar" Command="{Binding CreateCommand}"
                HorizontalAlignment="Right" Padding="12,4"/>
      </StackPanel>
    </Border>

    <Rectangle Grid.Column="1" Fill="{DynamicResource ColumnDividerColor}"/>

    <!-- Coluna direita: perícias adicionadas (drop target para drag & drop) -->
    <Grid Grid.Column="2" x:Name="AddedPanel" RowDefinitions="Auto,*,Auto,Auto">
      <TextBlock Grid.Row="0" Text="Perícias selecionadas" FontWeight="SemiBold" Margin="0,0,0,6"/>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding AddedSkills}"
               SelectedItem="{Binding SelectedAddedSkill}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto,40,50">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Padding="4,2" Margin="4,0"
                      FontSize="10" Foreground="{DynamicResource SystemAccentColor}"
                      Content="{Binding Reference}"
                      Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Abrir PDF na página"/>
              <TextBlock Grid.Column="2" Text="{Binding Level, StringFormat='{}{0:+#;-#;0}'}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
              <TextBlock Grid.Column="3" Text="{Binding Cost, StringFormat='{}{0} pts'}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Grid.Row="2" Content="Remover selecionado"
              Command="{Binding RemoveSelectedCommand}"
              HorizontalAlignment="Right" Margin="0,6,0,0"/>
      <TextBlock Grid.Row="3"
                 Text="Adicione ao menos uma perícia para continuar."
                 Classes="ValidationHint"
                 IsVisible="{Binding HasNoSkills}"
                 Margin="0,6,0,0"/>
    </Grid>

  </Grid>
</UserControl>
