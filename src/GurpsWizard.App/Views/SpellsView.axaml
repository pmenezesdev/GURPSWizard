<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.SpellsView"
             x:DataType="vm:SpellsViewModel">

  <Grid ColumnDefinitions="*,350" RowDefinitions="*">
    
    <!-- Left: Selection Area -->
    <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,20,0">
      
      <!-- Filters Card -->
      <Border Classes="FeatureCard">
        <StackPanel Spacing="12">
          <TextBox Text="{Binding SearchQuery}" 
                   Watermark="BUSCAR MAGIAS..."
                   Background="Transparent"
                   BorderBrush="{DynamicResource ColorBorderRule}"
                   BorderThickness="0,0,0,1"/>
          
          <ComboBox ItemsSource="{Binding Colleges}"
                    SelectedItem="{Binding SelectedCollege}"
                    PlaceholderText="TODAS AS ESCOLAS"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    BorderBrush="{DynamicResource ColorBorderRule}"/>
        </StackPanel>
      </Border>

      <!-- Selection Grid -->
      <ScrollViewer Height="400">
        <ListBox x:Name="SearchResultsList"
                 Classes="SelectionGrid" 
                 ItemsSource="{Binding SearchResults}"
                 SelectedItem="{Binding SelectedLibrarySpell}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel HorizontalAlignment="Center"/>
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Panel Width="200" Height="50">
                 <Border Classes="SelBtn" 
                         Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                   <Grid ColumnDefinitions="*,Auto,Auto">
                      <TextBlock Text="{Binding Name}" 
                                 TextTrimming="CharacterEllipsis" 
                                 VerticalAlignment="Center" 
                                 FontSize="11"
                                 Margin="5,0"/>
                      <Button Grid.Column="1" Classes="RefBtn" Content="{Binding Reference}"
                              Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                              CommandParameter="{Binding}"
                              IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                              Margin="0,0,5,0"/>
                      <TextBlock Grid.Column="2" Text="{Binding Difficulty}" 
                                 FontSize="9" Opacity="0.6" VerticalAlignment="Center" Margin="5,0"/>
                   </Grid>
                 </Border>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>

      <!-- Action Area -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
         <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="NÍVEL RELATIVO:" VerticalAlignment="Center" FontSize="10" Opacity="0.6"/>
            <NumericUpDown Value="{Binding RelativeLevel}" Minimum="0" Maximum="20" Width="80"/>
         </StackPanel>
         <Button Classes="NavBtnPrimary" Content="ADICIONAR" Command="{Binding AddCommand}"/>
      </StackPanel>
    </StackPanel>

    <!-- Right: Added List -->
    <Border x:Name="AddedPanel" Grid.Column="1" Classes="FeatureCard">
      <Grid RowDefinitions="Auto,1,*,Auto">
        <TextBlock Grid.Row="0" Text="MAGIAS SELECIONADAS" 
                   HorizontalAlignment="Center" FontSize="12" LetterSpacing="0.1" Margin="0,0,0,10"/>
        <Rectangle Grid.Row="1" Fill="{DynamicResource ColorBorderRule}" Margin="0,0,0,10"/>
        
        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding AddedSpells}" 
                 SelectedItem="{Binding SelectedAddedSpell}"
                 Background="Transparent" BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
               <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                 <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" TextWrapping="Wrap"/>
                 <Button Grid.Column="1" Classes="RefBtn" Content="{Binding Reference}"
                         Command="{Binding $parent[UserControl].DataContext.OpenReferenceCommand}"
                         CommandParameter="{Binding}"
                         IsVisible="{Binding Reference, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Margin="5,0"/>
                 <TextBlock Grid.Column="2" Text="{Binding Level, StringFormat='v{0}'}" 
                            FontSize="9" Opacity="0.5" Margin="5,0" VerticalAlignment="Center"/>
                 <TextBlock Grid.Column="3" Text="{Binding Cost, StringFormat='{}{0} pts'}" 
                            FontSize="11" Opacity="0.8" VerticalAlignment="Center"/>
               </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="3" 
                Classes="NavBtnSecondary" 
                Content="REMOVER SELECIONADO" 
                Command="{Binding RemoveSelectedCommand}"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                FontSize="10"/>
      </Grid>
    </Border>

  </Grid>
</UserControl>
