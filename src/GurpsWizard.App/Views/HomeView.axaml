<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels"
             x:Class="GurpsWizard.App.Views.HomeView"
             x:DataType="vm:HomeViewModel">

  <Grid RowDefinitions="Auto,*,Auto,Auto,*,Auto">

    <!-- Barra de Ferramentas Superior -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="8">
      <!-- Configurações (Esquerda) -->
      <Button Grid.Column="0" Command="{Binding ShowSettingsCommand}"
              Classes="IconButton" ToolTip.Tip="Configurações">
        <TextBlock Text="⚙" FontSize="20" Opacity="0.7"/>
      </Button>

      <!-- Botão de tema (Direita) -->
      <Button Grid.Column="2" Command="{Binding ToggleThemeCommand}"
              Classes="IconButton" ToolTip.Tip="Alternar tema">
        <Panel>
          <TextBlock Text="Claro"  IsVisible="{Binding Theme.IsDark}"  FontSize="12"/>
          <TextBlock Text="Escuro" IsVisible="{Binding !Theme.IsDark}" FontSize="12"/>
        </Panel>
      </Button>
    </Grid>

    <!-- Logo/Título -->
    <StackPanel Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Spacing="6" Margin="0,0,0,16">
      <TextBlock Text="GURPS Wizard" FontSize="40" FontWeight="Bold"
                 Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center"/>
      <TextBlock Text="Criação de personagens simplificada" FontSize="15" Opacity="0.6"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="4ª Edição · Basic Set" FontSize="11" Opacity="0.4"
                 HorizontalAlignment="Center" FontStyle="Italic"/>
    </StackPanel>

    <!-- Separador ornamental GURPS -->
    <Grid Grid.Row="2" Classes="GurpsRule" Width="260" HorizontalAlignment="Center"
          ColumnDefinitions="*,Auto,*" Margin="0,0,0,20">
      <Rectangle Grid.Column="0"/>
      <TextBlock Grid.Column="1" Text="*"/>
      <Rectangle Grid.Column="2"/>
    </Grid>

    <!-- Botões principais -->
    <StackPanel Grid.Row="3" Spacing="14" HorizontalAlignment="Center">
      <Button Content="Novo Personagem"
              Command="{Binding NewCharacterCommand}"
              Width="248" Height="52"
              FontSize="16"
              Classes="AccentButton"
              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

      <Button Content="Personagens Salvos"
              Command="{Binding ListCharactersCommand}"
              Width="248" Height="52"
              FontSize="15"
              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
    </StackPanel>

    <!-- Rodapé -->
    <TextBlock Grid.Row="5" Text="v0.1 MLP · GURPS Wizard" VerticalAlignment="Bottom"
               HorizontalAlignment="Center"
               Opacity="0.25" FontSize="11" Margin="0,0,0,14"/>

  </Grid>
</UserControl>
