<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels"
             xmlns:views="clr-namespace:GurpsWizard.App.Views"
             x:Class="GurpsWizard.App.Views.HomeView"
             x:DataType="vm:HomeViewModel">

  <UserControl.Resources>
    <views:BitmapAssetValueConverter x:Key="variableImageConverter"/>
  </UserControl.Resources>

  <Panel Classes="WizardScreen">
    
    <!-- Background Layer -->
    <Panel Name="BackgroundLayer">
      <Border Background="{StaticResource BackgroundGradient}"/>
      <Image Source="{Binding BackgroundImage, Converter={StaticResource variableImageConverter}}" 
             Stretch="UniformToFill" 
             VerticalAlignment="Top"
             Height="500"
             Opacity="0.5"
             IsVisible="{Binding BackgroundImage, Converter={x:Static ObjectConverters.IsNotNull}}">
        <Image.OpacityMask>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </LinearGradientBrush>
        </Image.OpacityMask>
      </Image>
      <Panel Background="{DynamicResource ColorOverlay}"/>
    </Panel>

    <StackPanel Classes="FinalScreenContent">
      
      <!-- Title Section -->
      <StackPanel Spacing="10" Margin="0,0,0,60">
        <TextBlock Classes="FinalScreenTitle" 
                   Text="GURPS WIZARD" 
                   FontSize="72"
                   Foreground="{DynamicResource ColorGoldBright}"/>
        <TextBlock Text="CRIAÇÃO DE PERSONAGEM SIMPLIFICADA" 
                   HorizontalAlignment="Center" 
                   FontSize="14" 
                   LetterSpacing="0.2" 
                   Opacity="0.9"
                   Foreground="{DynamicResource ColorGoldMid}"
                   FontFamily="{StaticResource FontDisplay}"/>
        <TextBlock Text="4ª EDIÇÃO · MÓDULO BÁSICO" 
                   HorizontalAlignment="Center" 
                   FontSize="10" 
                   Opacity="0.7" 
                   FontStyle="Italic"
                   Margin="0,5,0,0"/>
      </StackPanel>

      <!-- Main Actions -->
      <StackPanel Spacing="25">
        
        <StackPanel Classes="StartBtnWrapper">
          <TextBlock Classes="StartBtnOrnament" Text="❖"/>
          <Button Classes="StartBtn" 
                  Content="NOVA AVENTURA" 
                  Command="{Binding NewCharacterCommand}"/>
          <TextBlock Classes="StartBtnOrnament" Text="❖"/>
        </StackPanel>

        <Button Classes="NavBtnSecondary" 
                Content="PERSONAGENS SALVOS" 
                Command="{Binding ListCharactersCommand}"
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="{DynamicResource ColorGoldBright}"/>
        
        <Button Classes="NavBtnSecondary" 
                Content="CONFIGURAÇÕES" 
                Command="{Binding ShowSettingsCommand}"
                HorizontalAlignment="Center"
                FontSize="11"
                Opacity="0.8"/>
      </StackPanel>

    </StackPanel>

    <!-- Version Footer -->
    <TextBlock VerticalAlignment="Bottom" 
               HorizontalAlignment="Center" 
               Text="v0.1 MLP · GURPS Wizard" 
               FontSize="9" 
               Opacity="0.2" 
               Margin="0,0,0,15"/>

  </Panel>
</UserControl>
