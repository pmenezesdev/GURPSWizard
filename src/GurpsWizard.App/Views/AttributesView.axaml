<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             x:Class="GurpsWizard.App.Views.AttributesView"
             x:DataType="vm:AttributesViewModel">

  <StackPanel HorizontalAlignment="Center">
    <UniformGrid Columns="2" MaxWidth="600" HorizontalAlignment="Center">
      
      <!-- ST -->
      <Border Classes="StatCard" Margin="8">
        <StackPanel Spacing="10">
          <TextBlock Classes="StatCardName" Text="FORÇA (ST)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementST}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding ST}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementST}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostST, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="11"/>
        </StackPanel>
      </Border>

      <!-- DX -->
      <Border Classes="StatCard" Margin="8">
        <StackPanel Spacing="10">
          <TextBlock Classes="StatCardName" Text="DESTREZA (DX)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementDX}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding DX}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementDX}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostDX, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="11"/>
        </StackPanel>
      </Border>

      <!-- IQ -->
      <Border Classes="StatCard" Margin="8">
        <StackPanel Spacing="10">
          <TextBlock Classes="StatCardName" Text="INTELIGÊNCIA (IQ)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementIQ}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding IQ}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementIQ}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostIQ, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="11"/>
        </StackPanel>
      </Border>

      <!-- HT -->
      <Border Classes="StatCard" Margin="8">
        <StackPanel Spacing="10">
          <TextBlock Classes="StatCardName" Text="VITALIDADE (HT)"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <Button Classes="StatCardBtn" Content="−" Command="{Binding DecrementHT}"/>
            <TextBlock Classes="StatCardValue" Text="{Binding HT}"/>
            <Button Classes="StatCardBtn" Content="+" Command="{Binding IncrementHT}"/>
          </StackPanel>
          <TextBlock Text="{Binding CostHT, StringFormat='{}{0:+#;-#;0} pts'}" 
                     HorizontalAlignment="Center" Opacity="0.5" FontSize="11"/>
        </StackPanel>
      </Border>

    </UniformGrid>

    <TextBlock Margin="0,20,0,0" Opacity="0.5" FontSize="11" HorizontalAlignment="Center"
               Text="ST/HT = 10 pts/nível · DX/IQ = 20 pts/nível"/>
  </StackPanel>
</UserControl>
