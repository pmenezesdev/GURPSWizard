<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels"
             xmlns:vmSteps="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             xmlns:views="clr-namespace:GurpsWizard.App.Views"
             x:Class="GurpsWizard.App.Views.WizardView"
             x:DataType="vm:WizardViewModel">

  <!-- Roteamento de ViewModels → Views (específico do Wizard) -->
  <UserControl.DataTemplates>
    <DataTemplate DataType="{x:Type vmSteps:ConceptViewModel}">
      <views:ConceptView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:AttributesViewModel}">
      <views:AttributesView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:SecondaryViewModel}">
      <views:SecondaryView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:AdvantagesViewModel}">
      <views:TraitsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:DisadvantagesViewModel}">
      <views:TraitsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:SkillsViewModel}">
      <views:SkillsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:EquipmentViewModel}">
      <views:EquipmentView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:ReviewViewModel}">
      <views:ReviewView/>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ── Barra superior ─────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Classes="TopBar" Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <TextBlock Text="GURPS Wizard" FontSize="18" FontWeight="Bold"
                     Foreground="{DynamicResource AccentColor}"/>
          <TextBlock Text="·" Opacity="0.4" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding Draft.Name, FallbackValue='Novo Personagem'}"
                     FontSize="15" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

          <!-- Badge de pontos (animação suave ao mudar de estado) -->
          <Border Padding="14,6"
                  Classes="PointsBadge"
                  Classes.PointsBadgeWarning="{Binding IsOverBudget}">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.3"/>
              </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="{Binding Points.Spent}" FontWeight="Bold" FontSize="16"/>
              <TextBlock Text="/" Opacity="0.4"/>
              <TextBlock Text="{Binding Points.Total, StringFormat='{}{0} pts'}" Opacity="0.7"/>
            </StackPanel>
          </Border>

          <!-- Toggle de tema -->
          <Button Command="{Binding ToggleThemeCommand}"
                  Classes="IconButton" ToolTip.Tip="Alternar tema">
            <Panel>
              <TextBlock Text="Claro"  IsVisible="{Binding Theme.IsDark}"  FontSize="12"/>
              <TextBlock Text="Escuro" IsVisible="{Binding !Theme.IsDark}" FontSize="12"/>
            </Panel>
          </Button>

          <Button Content="Sair" Command="{Binding ExitCommand}"
                  Classes="DangerButton" Padding="12,6"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ── Área principal ────────────────────────────────────────────────── -->
    <Grid Grid.Row="1" ColumnDefinitions="190,1,*">

      <!-- Sidebar: etapas do wizard -->
      <Border Grid.Column="0" Classes="Sidebar">
        <ScrollViewer Padding="4,8">
          <ItemsControl ItemsSource="{Binding SidebarSteps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="IconButton" 
                        HorizontalAlignment="Stretch" 
                        Padding="0"
                        Command="{Binding $parent[UserControl].DataContext.JumpToStepCommand}"
                        CommandParameter="{Binding Index}">
                  <Border Classes="StepItem"
                          Classes.StepItemCurrent="{Binding IsCurrent}"
                          Background="Transparent"
                          HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="22,*">

                      <!-- Indicador: ✓ concluído | ● atual | número pendente -->
                      <TextBlock Grid.Column="0"
                                 Text="✓"
                                 Classes="StepIndexDone"
                                 IsVisible="{Binding IsCompleted}"
                                 FontWeight="Bold"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="0"
                                 Text="●"
                                 IsVisible="{Binding IsCurrent}"
                                 Foreground="{DynamicResource AccentColor}"
                                 FontSize="8"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Index, StringFormat='{}{0}'}"
                                 Classes="StepIndexPending"
                                 IsVisible="{Binding IsPending}"
                                 VerticalAlignment="Center"
                                 FontSize="11"/>

                      <TextBlock Grid.Column="1"
                                 Text="{Binding Title}"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Center"
                                 FontSize="13"/>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Rectangle Grid.Column="1" Fill="{DynamicResource DividerColor}"/>

      <!-- Área de conteúdo -->
      <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*">

        <!-- Cabeçalho da etapa -->
        <StackPanel Grid.Row="0" Margin="20,16,20,4">
          <TextBlock Text="{Binding CurrentStep.Title}" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding CurrentStep.Description}"
                     Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Barra de progresso -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding ProgressPercent}" Maximum="100"
                     Height="3" Margin="20,6,20,8"
                     Foreground="{DynamicResource AccentColor}"
                     Background="{DynamicResource DividerColor}"/>

        <!-- View da etapa atual (transição suave com CrossFade) -->
        <TransitioningContentControl Grid.Row="2"
                                     Content="{Binding CurrentStepViewModel}"
                                     Margin="20,0,20,12">
          <TransitioningContentControl.PageTransition>
            <CrossFade Duration="0:0:0.2"/>
          </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>

      </Grid>

    </Grid>

    <!-- ── Rodapé: navegação ─────────────────────────────────────────────── -->
    <Border Grid.Row="2" Classes="Footer" Padding="16,10">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" Opacity="0.5"
                   Classes.PointsWarning="{Binding IsOverBudget}"
                   Text="{Binding Points.Remaining, StringFormat='Pontos restantes: {0}'}"/>
        <Button Grid.Column="1" Content="← Voltar"
                Command="{Binding BackCommand}"
                Margin="0,0,8,0" Classes="NavButton"/>
        <Button Grid.Column="2" Content="Próximo →"
                Command="{Binding NextCommand}"
                Classes="NavButton AccentButton"/>
      </Grid>
    </Border>

  </Grid>
</UserControl>
