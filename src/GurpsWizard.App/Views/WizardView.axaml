<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GurpsWizard.App.ViewModels"
             xmlns:vmSteps="clr-namespace:GurpsWizard.App.ViewModels.Steps"
             xmlns:views="clr-namespace:GurpsWizard.App.Views"
             x:Class="GurpsWizard.App.Views.WizardView"
             x:DataType="vm:WizardViewModel">

  <UserControl.Resources>
    <views:BitmapAssetValueConverter x:Key="variableImageConverter"/>
  </UserControl.Resources>

  <!-- Roteamento de ViewModels → Views (específico do Wizard) -->
  <UserControl.DataTemplates>
    <DataTemplate DataType="{x:Type vmSteps:ConceptViewModel}">
      <views:ConceptView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:AttributesViewModel}">
      <views:AttributesView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:SecondaryViewModel}">
      <views:SecondaryView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:AdvantagesViewModel}">
      <views:TraitsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:DisadvantagesViewModel}">
      <views:TraitsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:SkillsViewModel}">
      <views:SkillsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:TechniquesViewModel}">
      <views:TechniquesView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:SpellsViewModel}">
      <views:SpellsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:EquipmentViewModel}">
      <views:EquipmentView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSteps:ReviewViewModel}">
      <views:ReviewView/>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Panel Classes="WizardScreen">
    
    <!-- ── Background Layer ──────────────────────────────────────────────── -->
    <Panel Name="BackgroundLayer">
      <!-- Fallback Gradient -->
      <Border Background="{StaticResource BackgroundGradient}"/>
      
      <!-- Optional Image Layer (Fading to bottom) -->
      <Image Source="{Binding BackgroundImage, Converter={StaticResource variableImageConverter}}" 
             Stretch="UniformToFill" 
             VerticalAlignment="Top"
             Height="450"
             Opacity="0.6"
             IsVisible="{Binding BackgroundImage, Converter={x:Static ObjectConverters.IsNotNull}}">
        <Image.OpacityMask>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </LinearGradientBrush>
        </Image.OpacityMask>
        <Image.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.5"/>
          </Transitions>
        </Image.Transitions>
      </Image>
      
      <!-- Overlay sutil -->
      <Panel Background="{DynamicResource ColorOverlay}"/>
    </Panel>

    <Grid RowDefinitions="50,*,60">

      <!-- ── Header ───────────────────────────────────────────────────────── -->
      <Border Grid.Row="0" Classes="WizardHeader">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" 
                     Classes="WizardHeaderTitle" 
                     Text="ASSISTENTE DE CRIAÇÃO DE PERSONAGEM GURPS"/>
          
          <Button Grid.Column="1" 
                  Classes="WizardHeaderExit" 
                  Content="✕ SAIR" 
                  Command="{Binding ExitCommand}"/>
        </Grid>
      </Border>

      <!-- ── Content Area ─────────────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Classes="WizardContent">
          
          <!-- Page Info -->
          <TextBlock Classes="WizardPageTitle" Text="{Binding CurrentStep.Title}"/>
          <TextBlock Classes="WizardPageStep" Text="{Binding StepIndicator}"/>
          <Rectangle Classes="WizardDivider"/>

          <!-- Main Content Block (Step View) -->
          <TransitioningContentControl Content="{Binding CurrentStepViewModel}">
            <TransitioningContentControl.PageTransition>
              <PageSlide Duration="0:0:0.35" Orientation="Horizontal"/>
            </TransitioningContentControl.PageTransition>
          </TransitioningContentControl>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Footer Nav ───────────────────────────────────────────────────── -->
      <Border Grid.Row="2" Classes="WizardFooter">
        <Grid ColumnDefinitions="Auto,*,Auto">
          
          <!-- Left: Cancel / Previous -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
            <Button Classes="NavBtnSecondary" 
                    Content="✕ CANCELAR" 
                    Command="{Binding ExitCommand}"
                    IsVisible="{Binding !CanGoBack}"/>
            
            <Button Classes="NavBtnSecondary" 
                    Content="← ANTERIOR" 
                    Command="{Binding BackCommand}"
                    IsVisible="{Binding CanGoBack}"/>
          </StackPanel>

          <!-- Center: Points Info (Optional, fits well here) -->
          <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{Binding Points.Remaining, StringFormat='Pontos Restantes: {0}'}" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ColorGoldAccent}"
                       HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="10" Opacity="0.6">
              <TextBlock Text="{Binding Points.Spent, StringFormat='Total Gasto: {0}'}" FontSize="10"/>
              <TextBlock Text="|" FontSize="10"/>
              <TextBlock Text="{Binding Draft.Name, FallbackValue='Sem Nome'}" FontSize="10"/>
            </StackPanel>
          </StackPanel>

          <!-- Right: Next / Finish -->
          <Panel Grid.Column="2">
            <Button Classes="NavBtnPrimary" 
                    Content="PRÓXIMO →" 
                    Command="{Binding NextCommand}"
                    IsVisible="{Binding !IsLastStep}"/>
            
            <Button Classes="NavBtnPrimary" 
                    Content="FINALIZAR" 
                    Command="{Binding NextCommand}"
                    IsVisible="{Binding IsLastStep}"/>
          </Panel>
          
        </Grid>
      </Border>

    </Grid>
  </Panel>
</UserControl>
